# Terminal Web UI Configuration

# Server port (default: 3456)
PORT=3456

# Workspace directory (default: current directory)
# WORKSPACE_DIR=/path/to/workspace

# Debug mode
DEBUG=false

# LLM Provider (ollama, nvidia, or opencode-zen)
LLM_PROVIDER=ollama

# Ollama server URL (default: http://localhost:11434)
OLLAMA_HOST=http://localhost:11434

# NVIDIA NIM API key (for nvidia provider)
# NVIDIA_API_KEY=your-nvidia-api-key-here

# OpenCode Zen API key (for opencode-zen provider)
# Get your API key from: https://opencode.ai/zen
# OPENCODE_ZEN_API_KEY=your-opencode-zen-api-key-here
# Default model for OpenCode Zen (optional, defaults to deepseek-v4-flash-free)
# OPENCODE_ZEN_MODEL=deepseek-v4-flash-free

# Enable/disable chat feature
CHAT_ENABLED=true

# Enable/disable Text-to-Speech (TTS) feature
TTS_ENABLED=true
